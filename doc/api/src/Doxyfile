# --- INFORMAZIONI PROGETTO ---
PROJECT_NAME           = "PPSE Firmware"
# PROJECT_NUMBER viene passato dal Makefile come variabile d'ambiente
PROJECT_NUMBER         = $(PROJECT_NUMBER)
OUTPUT_DIRECTORY       = doc/api/.api-build
STRIP_FROM_PATH        = $(CURDIR)
INPUT                  = README.md \
                         firm/src \
                         firm/include
FILE_PATTERNS          = *.cpp *.hpp *.h *.c *.md
RECURSIVE              = YES
OPTIMIZE_OUTPUT_FOR_C  = YES
SOURCE_BROWSER         = YES
FULL_PATH_NAMES        = YES

# --- PREPROCESSORE ---
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = firm/include \
                         firm/src

# Definizioni Globali per la Documentazione
PREDEFINED             = DEBUG=0 \
                         GPSBAUD=9600 \
                         GPS_SYNC_REQ=1 \
                         GPS_SYNC_ACK=1 \
                         __PICO__=1

# --- UI AWESOME THEME ---
# Nota: i percorsi devono puntare alla posizione reale del tema rispetto alla root
GENERATE_TREEVIEW      = YES
HTML_EXTRA_STYLESHEET  = doc/api/src/doxygen-awesome/doxygen-awesome.css \
                         doc/api/src/doxygen-awesome/doxygen-awesome-sidebar-only.css
HTML_EXTRA_FILES       = doc/api/src/doxygen-awesome/doxygen-awesome-darkmode-toggle.js

# --- LATEX (Configurazione per PDF) ---
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
LATEX_BATCHMODE        = YES
EXTRA_PACKAGES         = amsmath amssymb fontawesome5
USE_PDFLATEX           = YES
PDF_HYPERLINKS         = YES

# --- GRAPHVIZ (Diagrammi) ---
HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
# DOT_CLEAN_UP non è un tag ufficiale in alcune versioni, ma lo lasciamo per compatibilità
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES

# --- LOGS ---
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
