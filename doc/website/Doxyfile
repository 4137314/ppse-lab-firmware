PROJECT_NAME           = "ppse-firmware"
PROJECT_NUMBER         = "v1.0.0"
STRIP_FROM_PATH        = ../../firm/src
INPUT                  = ../../README.md ../../firm/src
RECURSIVE              = YES
OPTIMIZE_OUTPUT_FOR_C  = YES
SOURCE_BROWSER         = YES

# --- UI Awesome Theme ---
GENERATE_TREEVIEW      = YES
HTML_EXTRA_STYLESHEET  = doxygen-awesome/doxygen-awesome.css \
                         doxygen-awesome/doxygen-awesome-sidebar-only.css
HTML_EXTRA_FILES       = doxygen-awesome/doxygen-awesome-darkmode-toggle.js

# --- LaTeX (Configurazione di Sicurezza) ---
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
LATEX_BATCHMODE        = YES
# Indispensabile per \frac e simboli matematici
EXTRA_PACKAGES         = amsmath amssymb fontawesome5

# --- Graphviz (Solo per HTML, leggero per PDF) ---
HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_CLEAN_UP           = YES
# Disattiviamo i Call Graph nel PDF per evitare il blocco di pdflatex
GENERATE_LEGEND        = YES
CLASS_GRAPH            = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
